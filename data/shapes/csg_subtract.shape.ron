// Box with a cylindrical hole — the hole uses combine: Subtract
(
    name: "csg_subtract",
    palette: { "metal": (2, 2, 2) },
    color: "metal",
    children: [
        (name: "base", shape: Box,
            bounds: (-4, -4, -4, 4, 4, 4),
            color: "metal"),
        (name: "hole", shape: Cylinder,
            bounds: (-2, -5, -2, 2, 5, 2),
            combine: Subtract),
    ],
)
