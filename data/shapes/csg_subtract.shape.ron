// Box with a cylindrical hole — the hole uses combine: Subtract
(
    name: "csg_subtract",
    palette: { "metal": (0.6, 0.6, 0.65) },
    color: "metal",
    children: [
        (name: "base", shape: Box,
            bounds: (-1, -1, -1, 1, 1, 1),
            color: "metal"),
        (name: "hole", shape: Cylinder,
            bounds: (-0.4, -2, -0.4, 0.4, 2, 0.4),
            combine: Subtract),
    ],
)
