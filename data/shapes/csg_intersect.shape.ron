// Box with corners clipped by a sphere
(
    name: "csg_intersect",
    palette: { "glass": (1, 2, 2) },
    color: "glass",
    children: [
        (name: "box", shape: Box,
            bounds: (-3, -3, -3, 3, 3, 3),
            color: "glass"),
        (name: "sphere", shape: Sphere,
            bounds: (-4, -4, -4, 4, 4, 4),
            combine: Clip),
    ],
)
