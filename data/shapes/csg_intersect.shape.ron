// Sphere clipped to a smaller box — produces a sphere with flat sides
(
    name: "csg_intersect",
    palette: { "glass": (1, 2, 2) },
    color: "glass",
    children: [
        (name: "sphere", shape: Sphere,
            bounds: (-10, -10, -10, 10, 10, 10),
            color: "glass"),
        (name: "clip_box", shape: Box,
            bounds: (-7, -7, -7, 7, 7, 7),
            combine: Clip),
    ],
)
