// Sphere clipped to a smaller box — produces a sphere with flat sides
(
    name: "csg_intersect",
    palette: { "glass": (1, 2, 2) },
    color: "glass",
    children: [
        (name: "sphere", shape: Sphere,
            bounds: (-1, -1, -1, 1, 1, 1),
            color: "glass"),
        (name: "clip_box", shape: Box,
            bounds: (-0.7, -0.7, -0.7, 0.7, 0.7, 0.7),
            combine: Clip),
    ],
)
