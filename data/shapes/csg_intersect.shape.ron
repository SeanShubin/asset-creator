// CSG Intersect: sphere clipped to a box — produces a sphere with flat sides
(
    name: "csg_intersect",
    palette: { "glass": (0.4, 0.6, 0.8) },
    csg: Intersect,
    color: "glass",
    children: [
        (name: "sphere", shape: Sphere,
            bounds: (-1, -1, -1, 1, 1, 1),
            color: "glass"),
        (name: "clip_box", shape: Box,
            bounds: (-0.7, -0.7, -0.7, 0.7, 0.7, 0.7),
            color: "glass"),
    ],
)
